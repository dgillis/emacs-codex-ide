;;; codex-ide-model-tests.el --- Tests for Codex model metadata -*- lexical-binding: t; -*-

;;; Commentary:

;; Focused tests for model metadata exposed through app-server.

;;; Code:

(require 'ert)
(require 'cl-lib)
(require 'codex-ide)

(ert-deftest codex-ide-reasoning-effort-options-use-model-list-metadata ()
  (cl-letf (((symbol-function 'codex-ide--available-models)
             (lambda (&optional _session)
               '(((id . "gpt-5.6-sol")
                  (model . "gpt-5.6-sol")
                  (supportedReasoningEfforts
                   . (((reasoningEffort . "low"))
                      ((reasoningEffort . "medium"))
                      ((reasoningEffort . "high"))
                      ((reasoningEffort . "xhigh"))
                      ((reasoningEffort . "max"))
                      ((reasoningEffort . "ultra"))))
                  (defaultReasoningEffort . "low")
                  (isDefault . t))))))
    (should (equal (codex-ide--reasoning-effort-options "gpt-5.6-sol")
                   '(:choices ("low" "medium" "high" "xhigh" "max" "ultra")
			      :default "low")))))

(ert-deftest codex-ide-reasoning-effort-options-use-default-model-for-empty-name ()
  (let ((codex-ide-model "gpt-5.4"))
    (cl-letf (((symbol-function 'codex-ide--available-models)
               (lambda (&optional _session)
                 '(((model . "gpt-5.4")
                    (supportedReasoningEfforts
                     . (((reasoningEffort . "medium"))))
                    (defaultReasoningEffort . "medium")
                    (isDefault . :json-false))
                   ((model . "gpt-5.6-sol")
                    (supportedReasoningEfforts
                     . (((reasoningEffort . "low"))))
                    (defaultReasoningEffort . "low")
                    (isDefault . t))))))
      (should (equal (codex-ide--reasoning-effort-options "")
                     '(:choices ("low") :default "low"))))))

(ert-deftest codex-ide-reasoning-effort-options-honor-default-model-session-override ()
  (let ((codex-ide-model "gpt-configured")
        (session (make-codex-ide-session)))
    (codex-ide-config-set-session-value 'model nil session)
    (codex-ide--session-metadata-put session :model-name "gpt-remembered")
    (cl-letf (((symbol-function 'codex-ide--available-models)
               (lambda (&optional _session)
                 '(((model . "gpt-default")
                    (supportedReasoningEfforts
                     . (((reasoningEffort . "low"))))
                    (defaultReasoningEffort . "low")
                    (isDefault . t))
                   ((model . "gpt-remembered")
                    (supportedReasoningEfforts
                     . (((reasoningEffort . "high"))))
                    (defaultReasoningEffort . "high")
                    (isDefault . :json-false))))))
      (should (equal (codex-ide--reasoning-effort-options nil session)
                     '(:choices ("low") :default "low"))))))

(ert-deftest codex-ide-reasoning-effort-options-use-remembered-session-model ()
  (let ((codex-ide-model nil)
        (session (make-codex-ide-session)))
    (codex-ide--session-metadata-put session :model-name "gpt-5.5")
    (cl-letf (((symbol-function 'codex-ide--available-models)
               (lambda (&optional captured-session)
                 (should (eq captured-session session))
                 '(((model . "gpt-5.6-sol")
                    (supportedReasoningEfforts
                     . (((reasoningEffort . "low"))))
                    (defaultReasoningEffort . "low")
                    (isDefault . t))
                   ((model . "gpt-5.5")
                    (supportedReasoningEfforts
                     . (((reasoningEffort . "medium"))
                        ((reasoningEffort . "high"))
                        ((reasoningEffort . "xhigh"))))
                    (defaultReasoningEffort . "medium")
                    (isDefault . :json-false))))))
      (should (equal (codex-ide--reasoning-effort-options nil session)
                     '(:choices ("medium" "high" "xhigh")
                       :default "medium"))))))

(ert-deftest codex-ide-reasoning-effort-options-prefer-configured-model ()
  (let ((codex-ide-model "gpt-configured")
        (session (make-codex-ide-session)))
    (codex-ide--session-metadata-put session :model-name "gpt-remembered")
    (cl-letf (((symbol-function 'codex-ide--available-models)
               (lambda (&optional _session)
                 '(((model . "gpt-default")
                    (supportedReasoningEfforts
                     . (((reasoningEffort . "low"))))
                    (defaultReasoningEffort . "low")
                    (isDefault . t))
                   ((model . "gpt-remembered")
                    (supportedReasoningEfforts
                     . (((reasoningEffort . "medium"))))
                    (defaultReasoningEffort . "medium")
                    (isDefault . :json-false))
                   ((model . "gpt-configured")
                    (supportedReasoningEfforts
                     . (((reasoningEffort . "high"))))
                    (defaultReasoningEffort . "high")
                    (isDefault . :json-false))))))
      (should (equal (codex-ide--reasoning-effort-options nil session)
                     '(:choices ("high") :default "high"))))))


(ert-deftest codex-ide-available-model-names-reject-invalid-names ()
  (cl-letf (((symbol-function 'codex-ide--available-models)
             (lambda (&optional _session)
               '(((model . "gpt-valid"))
                 ((model . ""))
                 ((model . 42))
                 ((id . nil))))))
    (should (equal (codex-ide--available-model-names)
                   '("gpt-valid")))))

(ert-deftest codex-ide-available-models-cache-failures-within-one-interaction ()
  (dolist (result '(nil error))
    (let ((codex-ide--model-list-interaction-cache
           (make-hash-table :test #'equal))
          (fetch-count 0))
      (cl-letf (((symbol-function 'codex-ide--ensure-cli)
                 (lambda () t))
                ((symbol-function 'codex-ide--cleanup-dead-sessions)
                 (lambda () nil))
                ((symbol-function 'codex-ide--ensure-active-buffer-tracking)
                 (lambda () nil))
                ((symbol-function 'codex-ide--get-working-directory)
                 (lambda () "/tmp/codex-ide-model-cache/"))
                ((symbol-function
                  'codex-ide--query-session-for-thread-selection)
                 (lambda (&optional _directory) 'query-session))
                ((symbol-function 'codex-ide--list-models)
                 (lambda (&optional _session)
                   (setq fetch-count (1+ fetch-count))
                   (if (eq result 'error)
                       (error "model/list failed")
                     result))))
        (should-not (codex-ide--available-models))
        (should-not (codex-ide--available-models)))
      (should (= fetch-count 1)))))

(ert-deftest codex-ide-available-models-handle-working-directory-failure ()
  (cl-letf (((symbol-function 'codex-ide--get-working-directory)
             (lambda () (error "Working directory is unavailable"))))
    (should-not (codex-ide--available-models))))

(ert-deftest codex-ide-available-models-cache-is-request-and-directory-scoped ()
  (let ((directory "/tmp/codex-ide-model-cache-a/")
        (fetch-count 0))
    (cl-letf (((symbol-function 'codex-ide--ensure-cli)
               (lambda () t))
              ((symbol-function 'codex-ide--cleanup-dead-sessions)
               (lambda () nil))
              ((symbol-function 'codex-ide--ensure-active-buffer-tracking)
               (lambda () nil))
              ((symbol-function 'codex-ide--get-working-directory)
               (lambda () directory))
              ((symbol-function 'codex-ide--query-session-for-thread-selection)
               (lambda (&optional _directory) 'query-session))
              ((symbol-function 'codex-ide--list-models)
               (lambda (&optional _session)
                 (setq fetch-count (1+ fetch-count))
                 `(((model . ,directory))))))
      (let ((codex-ide--model-list-interaction-cache
             (make-hash-table :test #'equal)))
        (should (codex-ide--available-models))
        (setq directory "/tmp/codex-ide-model-cache-b/")
        (should (codex-ide--available-models)))
      (should (= fetch-count 2))
      (let ((codex-ide--model-list-interaction-cache
             (make-hash-table :test #'equal)))
        (should (codex-ide--available-models)))
      (should (= fetch-count 3)))))

(provide 'codex-ide-model-tests)

;;; codex-ide-model-tests.el ends here

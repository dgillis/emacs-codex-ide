(ert-deftest codex-ide-reasoning-effort-options-reject-malformed-efforts ()
  (dolist (efforts '(((reasoningEffort . "low"))
                     (((label . "Low")))
                     (((reasoningEffort . 1)))
                     (((reasoningEffort . "")))))
    (cl-letf (((symbol-function 'codex-ide--available-models)
               (lambda (&optional _session)
                 `(((model . "gpt-5.6-sol")
                    (supportedReasoningEfforts . ,efforts)
                    (defaultReasoningEffort . "low")
                    (isDefault . t))))))
      (should-not (codex-ide--reasoning-effort-options "gpt-5.6-sol")))))

